# Absolute path to the fastpdf-openrag-native repo checkout.
# This must be the native repo root, not fastpdf/openrag_native_bridge.
FASTPDF_OPENRAG_NATIVE_ROOT=/absolute/path/to/fastpdf-openrag-native

# Image/version selection.
OPENRAG_VERSION=latest

# Published ports.
FRONTEND_PORT=3000
LANGFLOW_PORT=7860
OPENSEARCH_PORT=9200
OPENSEARCH_METRICS_PORT=9600
DASHBOARDS_PORT=5601

# OpenSearch security + index settings.
OPENSEARCH_HOST=opensearch
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=replace-me
OPENSEARCH_INDEX_NAME=documents

# Persistent state directories. Relative paths are resolved from this deploy directory.
OPENRAG_DOCUMENTS_PATH=./state/openrag-documents
OPENRAG_KEYS_PATH=./state/keys
OPENRAG_FLOWS_PATH=./state/flows
OPENRAG_CONFIG_PATH=./state/config
OPENRAG_DATA_PATH=./state/data
OPENSEARCH_DATA_PATH=./state/opensearch-data

# Langflow / OpenRAG flow wiring.
LANGFLOW_SECRET_KEY=replace-me
LANGFLOW_PUBLIC_URL=http://127.0.0.1:7860
LANGFLOW_AUTO_LOGIN=true
LANGFLOW_NEW_USER_IS_ACTIVE=true
LANGFLOW_ENABLE_SUPERUSER_CLI=true
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=replace-me
LANGFLOW_CHAT_FLOW_ID=replace-with-exported-chat-flow-id
LANGFLOW_INGEST_FLOW_ID=replace-with-exported-ingest-flow-id
LANGFLOW_URL_INGEST_FLOW_ID=replace-with-exported-url-ingest-flow-id
NUDGES_FLOW_ID=
LANGFLOW_KEY=
LANGFLOW_KEY_RETRIES=15
LANGFLOW_KEY_RETRY_DELAY=2.0
LANGFLOW_TIMEOUT=2400
LANGFLOW_CONNECT_TIMEOUT=30
LANGFLOW_WORKERS=1

# Backend/session settings.
SESSION_SECRET=replace-me
SERVICE_NAME=fastpdf-openrag-native
LOG_LEVEL=INFO
LOG_FORMAT=plain
ACCESS_LOG=true
NO_COLOR=

# LLM / embedding providers.
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
COHERE_API_KEY=
OLLAMA_ENDPOINT=
SELECTED_EMBEDDING_MODEL=text-embedding-3-large

# Optional alternate providers.
WATSONX_API_KEY=
WATSONX_ENDPOINT=
WATSONX_PROJECT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Ingestion/runtime toggles.
DISABLE_INGEST_WITH_LANGFLOW=false
INGEST_SAMPLE_DATA=false
INGESTION_TIMEOUT=3600
UPLOAD_BATCH_SIZE=25
MAX_WORKERS=4
DOCLING_OCR_ENGINE=rapidocr
DOCLING_IMAGE=ghcr.io/docling-project/docling-serve:v1.14.3
DOCLING_PORT=5001
DOCLING_SERVE_ENABLE_UI=false
DOCLING_SERVE_API_KEY=
DOCLING_SERVE_URL=http://docling:5001

# Native repo hotfix + rerank settings.
FASTPDF_OPENRAG_BACKEND_RERANK_ENABLED=true
FASTPDF_OPENRAG_BACKEND_RERANK_PROVIDER=cross_encoder
FASTPDF_OPENRAG_BACKEND_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
FASTPDF_OPENRAG_BACKEND_RERANK_TOP_N=8
FASTPDF_OPENRAG_BACKEND_SEARCH_RERANK_ENABLED=true
FASTPDF_OPENRAG_BACKEND_SEARCH_RERANK_CANDIDATE_LIMIT=24

# Optional external Docling override. Leave these unset when using the bundled Compose docling service.
DOCLING_MANAGED=false
DOCLING_BIN=
DOCLING_HOST=0.0.0.0
DOCLING_BIND_PORT=5001
DOCLING_HEALTH_URL=http://127.0.0.1:5001/health
DOCLING_PID_FILE=
DOCLING_LOG_FILE=
